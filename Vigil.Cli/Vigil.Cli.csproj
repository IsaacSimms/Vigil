<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\Vigil.Application\Vigil.Application.csproj" />
    <ProjectReference Include="..\Vigil.Infrastructure\Vigil.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Spectre.Console.Cli" Version="0.49.*" />
    <!-- DI for composition root per grill-me clarifications and §3 -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.0" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>vigil</AssemblyName>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>vigil</ToolCommandName>
    <PackageId>Vigil.Cli</PackageId>
    <Version>1.0.0</Version>
  </PropertyGroup>

</Project>